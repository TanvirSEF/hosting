  "contact": {
    "title": "Questions About This Policy?",
    "description": "If you have any questions or concerns about this policy or how we handle your data, please don't hesitate to reach out to our team.",
    "button": "Contact Us"
  },
  "sections": [
    {
      "title": "Summary of key points",
      "content": "",
      "subsections": [
        {
          "content": {
            "type": "root",
            "children": [
              {
                "type": "p",
                "children": [
                  {
                    "type": "text",
                    "text": "We process personal information you provide to us when you create an account, place an order, use our Services, or contact support."
                  }
                ]
              },
              {
                "type": "p",
                "children": [
                  {
                    "type": "text",
                    "text": "We do not intentionally collect sensitive personal information."
                  }
                ]
              },
              {
                "type": "p",
                "children": [
                  {
                    "type": "text",
                    "text": "We primarily collect data directly from you and via cookies/technical logs on our website and hosting platform."
                  }
                ]
              },
              {
                "type": "p",
                "children": [
                  {
                    "type": "text",
                    "text": "We process your data to provide and improve our Services, handle billing, prevent fraud and abuse, secure our infrastructure, and comply with applicable law (including GDPR, if you are in the EU/EEA)."
                  }
                ]
              },
              {
                "type": "p",
                "children": [
                  {
                    "type": "text",
                    "text": "We may share your data with selected service providers (for example payment gateways, domain registries, data centers, and technical partners) when necessary to deliver the Services."
                  }
                ]
              },
              {
                "type": "p",
                "children": [
                  {
                    "type": "text",
                    "text": "We implement appropriate technical and organisational measures to protect your data, but no system can be 100% secure."
                  }
                ]
              },
              {
                "type": "p",
                "children": [
                  {
                    "type": "text",
                    "text": "Depending on where you are located, you may have rights such as access, rectification, erasure, restriction, objection, and data portability under applicable data protection law (including GDPR for EU/EEA users)."
                  }
                ]
              }
            ]
          }
        }
      ]
    },
    {
