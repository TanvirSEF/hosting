        },
        {
          "title": "Payment data",
          "content": {
            "type": "root",
            "children": [
              {
                "type": "p",
                "children": [
                  {
                    "type": "text",
                    "text": "If you choose to make purchases, we may process data necessary to handle your payment (for example transaction ID, payment method, partial card details as provided by the payment gateway). The full card details are typically processed directly by our payment service providers in accordance with their security standards."
                  }
                ]
              }
            ]
          }
        },
        {
          "title": "Data related to your hosting account",
          "content": {
            "type": "root",
            "children": [
              {
                "type": "p",
                "children": [
                  {
                    "type": "text",
                    "text": "When you use our hosting Services, we may process:"
                  }
                ]
              },
              {
                "type": "ol",
                "children": [
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "Domain names you register, transfer, or point to our platform."
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "Configuration data for your websites, email accounts, databases, and DNS."
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "Log data generated by servers and systems, such as access logs, error logs, and security logs, which can include IP addresses and timestamps."
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        },
