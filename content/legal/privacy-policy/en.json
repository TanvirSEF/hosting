    {
      "title": "How do we use your personal information?",
      "content": {
        "type": "root",
        "children": [
          {
            "type": "p",
            "children": [
              {
                "type": "text",
                "text": "We process your personal information for the following purposes:"
              }
            ]
          },
          {
            "type": "ul",
            "children": [
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "To create and manage your WebblyHosting account and hosting services."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "To process orders, payments, invoicing, and renewals."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "To register, transfer, and manage domain names through relevant registries and registrars."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "To provide customer support and communicate with you regarding your services, incidents, and requests."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "To send important service messages (for example security notices, system maintenance, changes to terms)."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "To maintain and improve the security, stability, and performance of our infrastructure."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "To analyse how our Services are used so we can improve features, performance, and user experience."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "To comply with legal obligations (for example accounting, tax, and data protection requirements)."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "To send marketing communications about our services when permitted by law and with the ability to opt out at any time."
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "p",
            "children": [
              {
                "type": "text",
                "text": "We only process your personal information when we have a valid legal basis, such as:"
              }
            ]
          },
          {
            "type": "ul",
            "children": [
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "Performance of a contract (for example providing hosting services you ordered)."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "Compliance with legal obligations."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "Legitimate interests (for example improving our services, preventing abuse and fraud, securing our systems) balanced against your rights and freedoms."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "Your consent, where required (for example certain marketing communications or non‑essential cookies)."
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "title": "When and with whom do we share your personal information?",
      "content": {
        "type": "root",
        "children": [
          {
            "type": "p",
            "children": [
              {
                "type": "text",
                "text": "We may share your personal information with:"
              }
            ]
          },
          {
            "type": "ul",
            "children": [
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "Service providers and subprocessors who help us deliver our Services (for example data centers, domain registrars, SSL providers, email service providers, payment gateways, support tools), under appropriate data processing agreements."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "Registries and ICANN‑related entities when you register or manage domain names, as required by registry/ICANN rules."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "Professional advisors (such as lawyers, accountants, auditors) where necessary."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "Public authorities or regulators where required by applicable law or in response to valid legal requests."
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "p",
            "children": [
              {
                "type": "text",
                "text": "We do not sell your personal information to third parties."
              }
            ]
          },
          {
            "type": "p",
            "children": [
              {
                "type": "text",
                "text": "If we are involved in a merger, acquisition, or sale of all or part of our business, your personal information may be transferred as part of that transaction, subject to applicable legal safeguards."
              }
            ]
          }
        ]
      }
    },
    {
      "title": " International transfers",
      "content": {
        "type": "root",
        "children": [
          {
            "type": "p",
            "children": [
              {
                "type": "text",
                "text": "Because our customers can be located worldwide and we may use infrastructure or service providers in different countries, your personal data may be transferred outside your country of residence, including outside the EU/EEA."
              }
            ]
          },
          {
            "type": "p",
            "children": [
              {
                "type": "text",
                "text": "Where required by law (for example for EU/EEA data subjects under GDPR), we will ensure that any international transfer is based on an appropriate safeguard, such as:"
              }
            ]
          },
          {
            "type": "ul",
            "children": [
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "An adequacy decision by the European Commission."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "Standard Contractual Clauses (SCCs) or equivalent contractual protections."
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "title": "How do we keep your information safe?",
      "content": {
        "type": "root",
        "children": [
          {
            "type": "p",
            "children": [
              {
                "type": "text",
                "text": "We implement appropriate technical and organisational measures to protect your personal information, including:"
              }
            ]
          },
          {
            "type": "ul",
            "children": [
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "Access controls and authentication on our systems and control panels."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "Encryption for data in transit (for example HTTPS/SSL) and, where appropriate, for data at rest."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "Regular security updates, monitoring, and logging."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "Backups and redundancy to reduce the risk of data loss."
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "p",
            "children": [
              {
                "type": "text",
