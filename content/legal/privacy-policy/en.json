            "children": [
              {
                "type": "p",
                "children": [
                  {
                    "type": "text",
                    "text": "When you visit, use, or navigate the Services, we automatically collect certain technical information. This does not directly reveal your specific identity (like your name) but may include:"
                  }
                ]
              },
              {
                "type": "ol",
                "children": [
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
