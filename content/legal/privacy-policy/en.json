                        ]
                      }
                    ]
                  },
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "Language settings"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "Referring URLs and pages visited"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "Date and time of access"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "Technical events (such as errors, security events, resource usage)"
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "p",
                "children": [
                  {
                    "type": "text",
                    "text": "This information is primarily needed to:"
                  }
