{
  "title": "Privacy Policy",
  "pageLastUpdated": "31 December 2025",
  "introduction": {
    "type": "root",
    "children": [
      {
        "type": "p",
        "children": [
          {
            "type": "text",
            "text": "This Privacy Notice for WebblyHosting (“we”, “us”, or “our”) describes how and why we access, collect, store, use, and/or share (“process”) your personal information when you use our services (“Services”), including when you:"
          }
        ]
      },
      {
        "type": "ul",
        "children": [
          {
            "type": "li",
            "children": [
              {
                "type": "lic",
                "children": [
                  {
                    "type": "text",
                    "text": "Visit our website webblyhosting.com or any website of ours that links to this Privacy Notice."
                  }
                ]
              }
            ]
          },
          {
            "type": "li",
            "children": [
              {
                "type": "lic",
                "children": [
                  {
                    "type": "text",
                    "text": "Use our hosting platform and related services (such as shared hosting, WordPress hosting, e‑commerce hosting and VPS hosting)."
                  }
                ]
              }
            ]
          },
          {
            "type": "li",
            "children": [
              {
                "type": "lic",
                "children": [
                  {
                    "type": "text",
                    "text": "Engage with us in other related ways, including any sales, customer support, marketing, or events."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "breadcrumb": {
    "home": "Home",
