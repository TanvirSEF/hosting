    {
      "title": "Hur använder vi dina personuppgifter?",
      "content": {
        "type": "root",
        "children": [
          {
            "type": "p",
            "children": [
              {
                "type": "text",
                "text": "Vi behandlar dina personuppgifter för följande ändamål:"
              }
            ]
          },
          {
            "type": "ul",
            "children": [
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "För att skapa och hantera ditt WebblyHosting-konto och hostingtjänster."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "För att behandla beställningar, betalningar, fakturering och förnyelser."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "För att registrera, överföra och hantera domännamn via relevanta register och registratorer."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "För att tillhandahålla kundsupport och kommunicera med dig angående dina tjänster, incidenter och förfrågningar."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "För att skicka viktiga servicemeddelanden (till exempel säkerhetsmeddelanden, systemunderhåll, ändringar av villkor)."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "För att upprätthålla och förbättra säkerheten, stabiliteten och prestandan för vår infrastruktur."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "För att analysera hur våra Tjänster används så att vi kan förbättra funktioner, prestanda och användarupplevelse."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "För att följa lagliga skyldigheter (till exempel bokförings-, skatte- och dataskyddskrav)."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "För att skicka marknadsföringsmeddelanden om våra tjänster när det är tillåtet enligt lag och med möjlighet att avregistrera sig när som helst."
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "p",
            "children": [
              {
                "type": "text",
                "text": "Vi behandlar bara dina personuppgifter när vi har en giltig rättslig grund, till exempel:"
              }
            ]
          },
          {
            "type": "ul",
            "children": [
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "Fullgörande av avtal (till exempel tillhandahållande av hostingtjänster som du beställt)."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "Efterlevnad av lagliga skyldigheter."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "Berättigade intressen (till exempel förbättring av våra tjänster, förebyggande av missbruk och bedrägeri, säkring av våra system) avvägda mot dina rättigheter och friheter."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "Ditt samtycke, där det krävs (till exempel vissa marknadsföringskommunikationer eller icke-nödvändiga cookies)."
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "title": "När och med vem delar vi dina personuppgifter?",
      "content": {
        "type": "root",
        "children": [
          {
            "type": "p",
            "children": [
              {
                "type": "text",
                "text": "Vi kan dela dina personuppgifter med:"
              }
            ]
          },
          {
            "type": "ul",
            "children": [
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "Tjänsteleverantörer och underbiträden som hjälper oss att leverera våra Tjänster (till exempel datacenter, domänregistratorer, SSL-leverantörer, e-postleverantörer, betalningsgateways, supportverktyg), under lämpliga databehandlingsavtal."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "Register och ICANN-relaterade enheter när du registrerar eller hanterar domännamn, enligt krav från register/ICANN-regler."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "Professionella rådgivare (såsom jurister, revisorer, granskare) där det är nödvändigt."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "Offentliga myndigheter eller tillsynsorgan där det krävs enligt tillämplig lag eller som svar på giltiga rättsliga förfrågningar."
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "p",
            "children": [
              {
                "type": "text",
                "text": "Vi säljer inte dina personuppgifter till tredje part."
              }
            ]
          },
          {
            "type": "p",
            "children": [
              {
                "type": "text",
                "text": "Om vi är involverade i en fusion, förvärv eller försäljning av hela eller delar av vår verksamhet kan dina personuppgifter överföras som en del av den transaktionen, med förbehåll för tillämpliga rättsliga skyddsåtgärder."
              }
            ]
          }
        ]
      }
    },
    {
      "title": "Internationella överföringar",
      "content": {
        "type": "root",
        "children": [
          {
            "type": "p",
            "children": [
              {
                "type": "text",
                "text": "Eftersom våra kunder kan befinna sig världen över och vi kan använda infrastruktur eller tjänsteleverantörer i olika länder, kan dina personuppgifter överföras utanför ditt hemland, inklusive utanför EU/EES."
              }
            ]
          },
          {
            "type": "p",
            "children": [
              {
                "type": "text",
                "text": "Där det krävs enligt lag (till exempel för EU/EES-registrerade under GDPR) kommer vi att säkerställa att eventuell internationell överföring baseras på en lämplig skyddsåtgärd, såsom:"
              }
            ]
          },
          {
            "type": "ul",
            "children": [
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "Ett adekvansbeslutet från Europeiska kommissionen."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "Standardavtalsklausuler (SCC) eller motsvarande avtalsskydd."
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "title": "Hur skyddar vi dina uppgifter?",
      "content": {
        "type": "root",
        "children": [
          {
            "type": "p",
            "children": [
              {
                "type": "text",
                "text": "Vi implementerar lämpliga tekniska och organisatoriska åtgärder för att skydda dina personuppgifter, inklusive:"
              }
            ]
          },
          {
            "type": "ul",
            "children": [
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "Åtkomstkontroller och autentisering på våra system och kontrollpaneler."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "li",
                "children": [
                  {
                    "type": "lic",
                    "children": [
                      {
                        "type": "text",
                        "text": "Kryptering för data under överföring (till exempel HTTPS/SSL) och, där det är lämpligt, för data i vila."
